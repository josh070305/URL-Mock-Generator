# Choose provider: "groq" | "openrouter" | "gemini" | "anthropic"
VITE_LLM_PROVIDER=groq

# Groq (free tier, independent limits) — https://console.groq.com/keys
VITE_GROQ_KEY=your-groq-key
# Optional model override (default: llama-3.3-70b-versatile)
VITE_MODEL=llama-3.3-70b-versatile

# OpenRouter (free models) — https://openrouter.ai/keys
VITE_OPENROUTER_KEY=your-openrouter-key
# VITE_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Google Gemini (free tier) — https://aistudio.google.com/apikey
VITE_GEMINI_KEY=your-gemini-key
VITE_GEMINI_MODEL=gemini-2.0-flash

# Anthropic (paid) — https://console.anthropic.com
VITE_ANTHROPIC_KEY=your-anthropic-key
